<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Golden Border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="6dp" android:color="#D4AF37" />
            <solid android:color="#FFFDF9" /> <!-- Light warm parchment background -->
        </shape>
    </item>
    <!-- Inner Golden Border -->
    <item android:top="12dp" android:bottom="12dp" android:left="12dp" android:right="12dp">
        <shape android:shape="rectangle">
            <stroke android:width="2dp" android:color="#D4AF37" />
            <solid android:color="#00000000" />
        </shape>
    </item>
</layer-list>
