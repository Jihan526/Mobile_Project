<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Deep Blue Border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="8dp" android:color="#1E3A8A" />
            <solid android:color="#F8FAFC" /> <!-- Clean cool grey background -->
        </shape>
    </item>
    <!-- Inner Grey Accent Line -->
    <item android:top="16dp" android:bottom="16dp" android:left="16dp" android:right="16dp">
        <shape android:shape="rectangle">
            <stroke android:width="1.5dp" android:color="#94A3B8" />
            <solid android:color="#00000000" />
        </shape>
    </item>
</layer-list>
