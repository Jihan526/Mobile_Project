<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:fitsSystemWindows="true"
    tools:context=".AuthActivity">

    <!-- Gradient Header Background -->
    <View
        android:id="@+id/view_header_bg"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="@drawable/bg_gradient_indigo"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- App Brand Header -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👑"
            android:textSize="50sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="나만의 상장 메이커"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="소중한 지인에게 마음을 전하는 가장 특별한 방법"
            android:textColor="#E0E7FF"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Main Container Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="30dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_header">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp">

            <!-- 1. SELECTOR VIEW -->
            <LinearLayout
                android:id="@+id/layout_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="32dp"
                    android:text="시작하기 단계를 선택해 주세요"
                    android:textColor="#374151"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Login Trigger Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_trigger_login"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="로그인하기"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="#4F46E5"
                    app:cornerRadius="12dp" />

                <!-- Register Trigger Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_trigger_register"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:text="이메일 회원가입"
                    android:textColor="#4F46E5"
                    app:cornerRadius="12dp"
                    app:strokeColor="#4F46E5"
                    app:strokeWidth="1.5dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="24dp"
                    android:background="#E5E7EB" />

                <!-- Guest Start Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_start_guest"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="비회원으로 시작하기"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="#10B981"
                    app:cornerRadius="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:text="* 비회원은 제작 한도가 2회로 제한됩니다."
                    android:textColor="#9CA3AF"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- 2. LOGIN FORM VIEW -->
            <LinearLayout
                android:id="@+id/layout_login_form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="로그인"
                    android:textColor="#1F2937"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Username -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxStrokeColor="#4F46E5"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_login_username"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:hint="아이디"
                        android:inputType="text"
                        android:textColor="#1F2937"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxStrokeColor="#4F46E5"
                    app:hintEnabled="false"
                    app:passwordToggleEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_login_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:hint="비밀번호"
                        android:inputType="textPassword"
                        android:textColor="#1F2937"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Submit Login -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_submit_login"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="24dp"
                    android:text="로그인 완료"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="#4F46E5"
                    app:cornerRadius="8dp" />

                <!-- Back button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_back_to_selector_from_login"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"
                    android:text="뒤로 가기"
                    android:textColor="#6B7280" />

            </LinearLayout>

            <!-- 3. REGISTER FORM VIEW -->
            <LinearLayout
                android:id="@+id/layout_register_form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="회원가입"
                    android:textColor="#1F2937"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Username -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxStrokeColor="#4F46E5"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_register_username"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:hint="사용할 아이디"
                        android:inputType="text"
                        android:textColor="#1F2937"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxStrokeColor="#4F46E5"
                    app:hintEnabled="false"
                    app:passwordToggleEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_register_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:hint="비밀번호"
                        android:inputType="textPassword"
                        android:textColor="#1F2937"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Nickname -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxStrokeColor="#4F46E5"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_register_nickname"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:hint="닉네임(상장에 표기될 이름)"
                        android:inputType="textPersonName"
                        android:textColor="#1F2937"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Submit Register -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_submit_register"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="24dp"
                    android:text="회원가입 완료"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="#4F46E5"
                    app:cornerRadius="8dp" />

                <!-- Back button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_back_to_selector_from_register"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"
                    android:text="뒤로 가기"
                    android:textColor="#6B7280" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
