<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    tools:context=".HomeFragment">

    <!-- Top Navigation Bar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="나만의 상장 만들기"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_gravity="center" />

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Main Scroll Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- FR-01: AI Award Text Generator Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1. 상장 문구 추가하기"
                        android:textColor="#374151"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="상장을 수여하는 가벼운 사유를 입력해 주세요."
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                    <!-- Recipient Name Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:boxStrokeColor="#4F46E5"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_recipient_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:hint="받는 사람 이름 (예: 홍길동)"
                            android:inputType="textPersonName"
                            android:textColor="#1F2937"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Award Reason Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:boxStrokeColor="#4F46E5"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_award_reason"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:hint="상장 수여 사유 (예: 매일 아침 맛있는 밥을 챙겨줌)"
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            android:textColor="#1F2937"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Issuer Name Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:boxStrokeColor="#4F46E5"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_issuer_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:hint="주는 사람 이름 (예: 고마운 가족)"
                            android:inputType="textPersonName"
                            android:textColor="#1F2937"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Award Date Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:boxStrokeColor="#4F46E5"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_award_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:hint="수여 날짜 (예: 2026년 6월 11일, 비워두면 오늘 날짜)"
                            android:inputType="text"
                            android:textColor="#1F2937"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_generate_text"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="AI 문구 생성"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:backgroundTint="#4F46E5"
                        app:cornerRadius="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- FR-02: Template Selection Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2. 배경 템플릿 선택"
                        android:textColor="#374151"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="상장의 분위기에 어울리는 테두리 템플릿을 선택해 주세요."
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                    <!-- RecyclerView for template selections (FR-02) -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_templates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_template" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- FR-03: Photo Sticker Section (Separated from Templates) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3. 사진 스티커 추가"
                        android:textColor="#374151"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="상장 내부에 배치할 사진을 촬영하거나 갤러리에서 불러옵니다."
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_camera_sticker"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="사진 촬영"
                            android:textColor="#4F46E5"
                            app:cornerRadius="8dp"
                            app:strokeColor="#4F46E5" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_gallery_sticker"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="4dp"
                            android:text="갤러리 로드"
                            android:textColor="#4F46E5"
                            app:cornerRadius="8dp"
                            app:strokeColor="#4F46E5" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_remove_sticker"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="사진 제거"
                            android:textColor="#EF4444"
                            app:cornerRadius="8dp"
                            app:strokeColor="#EF4444"
                            android:visibility="gone"
                            tools:visibility="visible" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- FR-08: Stamp Configuration -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4. 직인 도장 설정"
                        android:textColor="#374151"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="상장에 추가할 직인 도장을 표시하고, 도장 문구를 직접 입력하여 꾸밀 수 있습니다."
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_issuer_stamp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="수여인 직인 도장 표시"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:checked="true"
                        app:useMaterialThemeColors="true" />

                    <!-- Custom Stamp Text Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:boxStrokeColor="#4F46E5"
                        app:hintEnabled="false"
                        app:counterEnabled="true"
                        app:counterMaxLength="4">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_stamp_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:hint="도장 문구 입력 (최대 4자, 비워두면 수여인 이름)"
                            android:inputType="text"
                            android:maxLength="4"
                            android:textColor="#1F2937"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Certificate Canvas Section (FR-04 Capture Area) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"
                android:text="5. 상장 미리보기"
                android:textColor="#374151"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Container to enforce A4 Aspect Ratio inside LinearLayout -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_certificate_canvas"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:background="@color/white"
                    android:elevation="4dp"
                    app:layout_constraintDimensionRatio="1:1.414"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                <!-- Background Image of the Certificate -->
                <ImageView
                    android:id="@+id/iv_certificate_background"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    tools:srcCompat="@android:drawable/dialog_holo_light_frame" />

                <!-- Certificate Internal Content Container -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="24dp">

                    <!-- Title "상 장" -->
                    <TextView
                        android:id="@+id/tv_cert_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:text="상 장"
                        android:textColor="#111827"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.4"
                        android:fontFamily="@font/font_song_myung"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Recipient Name "이름: OOO" -->
                    <TextView
                        android:id="@+id/tv_cert_recipient"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:layout_marginStart="12dp"
                        android:text="이름 : 홍길동"
                        android:textColor="#1F2937"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/font_gowun_batang"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_cert_title" />

                    <!-- Custom Crop Image inside certificate (FR-03 Decoration) -->
                    <ImageView
                        android:id="@+id/iv_custom_image"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginTop="16dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_cert_recipient"
                        tools:srcCompat="@android:drawable/ic_menu_gallery"
                        tools:visibility="visible" />

                    <!-- Award Text/Content "위 사람은..." (FR-01 AI Text Result) -->
                    <TextView
                        android:id="@+id/tv_cert_content"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"
                        android:layout_marginHorizontal="12dp"
                        android:gravity="center|start"
                        android:lineSpacingExtra="6sp"
                        android:text="위 사람은 일상 속에서 타의 모범이 되는 훌륭한 모습을 보여주었기에 이 상장을 수여하여 칭찬하고 격려합니다."
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:fontFamily="@font/font_gowun_batang"
                        app:layout_constraintBottom_toTopOf="@id/tv_cert_date"
                        app:layout_constraintTop_toBottomOf="@id/iv_custom_image" />

                    <!-- Date "2026년 05월 26일" -->
                    <TextView
                        android:id="@+id/tv_cert_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="2026년 05월 26일"
                        android:textColor="#4B5563"
                        android:textSize="13sp"
                        android:fontFamily="@font/font_gowun_batang"
                        app:layout_constraintBottom_toTopOf="@id/tv_cert_issuer"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Issuer "수여인 : OOO" -->
                    <TextView
                        android:id="@+id/tv_cert_issuer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:text="수여인 : 홍길동"
                        android:textColor="#1F2937"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/font_gowun_batang"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Red Square Stamp TextView overlapping issuer name slightly -->
                    <TextView
                        android:id="@+id/tv_stamp_text"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="-8dp"
                        android:background="@drawable/bg_stamp_red"
                        android:gravity="center"
                        android:rotation="-6"
                        android:textColor="#D32F2F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="0.85"
                        android:fontFamily="@font/font_song_myung"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="@id/tv_cert_issuer"
                        app:layout_constraintStart_toEndOf="@id/tv_cert_issuer"
                        app:layout_constraintTop_toTopOf="@id/tv_cert_issuer"
                        tools:text="홍길\n동인"
                        tools:visibility="visible" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Bottom Operation Buttons (FR-04, FR-05) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_storage"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="12dp"
                android:text="보관함 저장"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="#4F46E5"
                app:cornerRadius="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_gallery"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="갤러리 저장"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="#10B981"
                    app:cornerRadius="8dp"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_share_sns"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="SNS 공유"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="#F59E0B"
                    app:cornerRadius="8dp"
                    app:iconGravity="textStart" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
